    "# evaluation\n",
    "import zipfile\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "from PIL import Image\n",
    "from sklearn.metrics import average_precision_score, roc_curve\n",
    "import gc\n",
    "\n",
    "MODELS_PIPELINE = {\n",
    "    \"EoMT (Fine-Tuned)\": m_ft,\n",
    "    \"EoMT (CS Base)\": orig_cs_model,\n",
    "    \"EoMT (COCO Base)\": orig_coco_model\n",
    "}\n",
    "\n",
    "DATASETS = [\"RoadAnomaly21\", \"RoadObsticle21\", \"FS_LostFound_full\", \"fs_static\", \"RoadAnomaly\"]\n",
    "METHODS = [\"MSP\", \"MaxLogit\", \"MaxEntropy\", \"RbA\"]\n",
    "ZIP_PATH = \"/content/drive/MyDrive/Project/Anomaly_Validation_Datasets.zip\"\n",
    "\n",
    "def calculate_fpr_at_95_tpr(anomaly_scores, labels):\n",
    "    fpr, tpr, thresholds = roc_curve(labels, anomaly_scores)\n",
    "    idx = np.argmax(tpr >= 0.95)\n",
    "    return fpr[idx]\n",
    "\n",
    "print(\"\u2699\ufe0f Launching Optimized All-in-One OOD Pipeline...\")\n",
    "\n",
    "for model_name, model_obj in MODELS_PIPELINE.items():\n",
    "    model_obj.eval()\n",
    "    print(\"=\" * 85)\n",
    "    print(f\" CURRENT EVALUATION TARGET: {model_name}\")\n",
    "    print(\"=\" * 85)\n",
    "    \n",
    "    for dataset_name in DATASETS:\n",
    "        print(f\"\\nProcessing Dataset: [{dataset_name}]\")\n",
    "        \n",
    "        scores_dict = {m: [] for m in METHODS}\n",
    "        ood_gts_list = []\n",
    "        \n",
    "        with zipfile.ZipFile(ZIP_PATH, 'r') as zip_ref:\n",
    "            img_paths = sorted([f for f in zip_ref.namelist() if dataset_name in f and \"/images/\" in f and f.lower().endswith(('.png', '.jpg', '.webp'))])\n",
    "            \n",
    "            if not img_paths:\n",
    "                continue\n",
    "                \n",
    "            crop_h, crop_w = (1024, 1024) if model_name == \"EoMT (CS Base)\" else (640, 640)\n",
    "            \n",
    "            with torch.no_grad():\n",
    "                for img_path_in_zip in img_paths:\n",
    "                    with zip_ref.open(img_path_in_zip) as file:\n",
    "                        img_pil = Image.open(file).convert('RGB').resize((1024, 512), Image.BILINEAR)\n",
    "                        img_tensor = torch.from_numpy(np.array(img_pil)).permute(2, 0, 1).byte().to(device)\n",
    "                        \n",
    "                    with torch.amp.autocast(dtype=torch.float16, device_type=\"cuda\"):\n",
    "                        crops, origins = model_obj.window_imgs_semantic([img_tensor])\n",
    "                        mask_logits_per_layer, class_logits_per_layer = model_obj(crops)\n",
    "                        \n",
    "                        mask_logits_up = F.interpolate(mask_logits_per_layer[-1], (crop_h, crop_w), mode=\"bilinear\")\n",
    "                        crop_logits = model_obj.to_per_pixel_logits_semantic(mask_logits_up, class_logits_per_layer[-1])\n",
    "                        logits = model_obj.revert_window_logits_semantic(crop_logits, origins, [img_tensor.shape[-2:]])[0]\n",
    "                        \n",
    "                        q_logits = class_logits_per_layer[-1]\n",
    "                        mask_probs = torch.sigmoid(mask_logits_up.float())\n",
    "                        \n",
    "                    logits = logits.float()\n",
    "                    if logits.ndim == 4: logits = logits[0]\n",
    "                    \n",
    "                    if logits.shape[0] == 20: \n",
    "                        logits = logits[:19, :, :]\n",
    "                        \n",
    "                    probs = F.softmax(logits, dim=0)\n",
    "                        \n",
    "                    gt_path = img_path_in_zip.replace(\"/images/\", \"/labels_masks/\").rsplit('.', 1)[0] + '.png'\n",
    "                    try:\n",
    "                        with zip_ref.open(gt_path) as file:\n",
    "                            raw_gts = np.array(Image.open(file).resize((1024, 512), Image.NEAREST))\n",
    "                            if raw_gts.ndim == 3: raw_gts = raw_gts[:, :, 0]\n",
    "                    except KeyError:\n",
    "                        continue\n",
    "                        \n",
    "                    target_dataset_lower = dataset_name.lower()\n",
    "                    ood_gts = np.full_like(raw_gts, 255, dtype=np.uint8)\n",
    "                    if set(np.unique(raw_gts)).issubset({0, 1, 255}) or \"roadanomaly\" in target_dataset_lower or \"roadobsticle\" in target_dataset_lower:\n",
    "                        ood_gts[raw_gts == 0] = 0\n",
    "                        ood_gts[(raw_gts == 1) | (raw_gts == 2)] = 1\n",
    "                    elif \"lostfound\" in target_dataset_lower or \"static\" in target_dataset_lower:\n",
    "                        ood_gts[raw_gts == 1] = 0\n",
    "                        ood_gts[(raw_gts > 1) & (raw_gts < 205)] = 1\n",
    "                        ood_gts[raw_gts == 0] = 255\n",
    "                        \n",
    "                    valid_mask = (ood_gts == 0) | (ood_gts == 1)\n",
    "                    if not np.any(valid_mask): continue\n",
    "                    \n",
    "                    valid_gts = ood_gts[valid_mask]\n",
    "                    ood_gts_list.append(valid_gts)\n",
    "                    \n",
    "                    # --- MSP ---\n",
    "                    max_prob, _ = torch.max(probs, dim=0)\n",
    "                    scores_dict[\"MSP\"].append((1.0 - max_prob).cpu().numpy()[valid_mask])\n",
    "                    \n",
    "                    # --- MaxLogit ---\n",
    "                    max_logit, _ = torch.max(logits, dim=0)\n",
    "                    scores_dict[\"MaxLogit\"].append((-max_logit).cpu().numpy()[valid_mask])\n",
    "                    \n",
    "                    # --- MaxEntropy ---\n",
    "                    entropy = -torch.sum(probs * torch.log(probs + 1e-7), dim=0)\n",
    "                    scores_dict[\"MaxEntropy\"].append(entropy.cpu().numpy()[valid_mask])\n",
    "                    \n",
    "                    # --- RbA ---\n",
    "                    B, Q, H_c, W_c = mask_probs.shape\n",
    "                    num_c = q_logits.shape[-1]\n",
    "                    q_probs_fg = F.softmax(q_logits.float(), dim=-1)[:, :, :-1] if num_c > 19 else torch.sigmoid(q_logits.float())\n",
    "                    max_fg_probs, _ = q_probs_fg.max(dim=-1)\n",
    "                    weighted_masks = max_fg_probs.view(B, Q, 1, 1) * mask_probs\n",
    "                    pixel_fg_score, _ = weighted_masks.max(dim=1)\n",
    "                    \n",
    "                    rba_crops = (1.0 - pixel_fg_score).unsqueeze(1)\n",
    "                    dummy_crops = torch.zeros((B, 19, H_c, W_c), device=device, dtype=rba_crops.dtype)\n",
    "                    dummy_crops[:, 0:1, :, :] = rba_crops\n",
    "                    rba_map = model_obj.revert_window_logits_semantic(dummy_crops, origins, [img_tensor.shape[-2:]])[0][0]\n",
    "                    scores_dict[\"RbA\"].append(rba_map.cpu().numpy()[valid_mask])\n",
    "                    \n",
    "                    del logits, probs, mask_logits_up, crop_logits, crops, origins, q_logits, mask_probs\n",
    "                    torch.cuda.empty_cache()\n",
    "                    \n",
    "        if len(ood_gts_list) > 0:\n",
    "            val_label = np.concatenate(ood_gts_list)\n",
    "            for m in METHODS:\n",
    "                val_out = np.concatenate(scores_dict[m])\n",
    "                auprc = average_precision_score(val_label, val_out) * 100.0\n",
    "                fpr95 = calculate_fpr_at_95_tpr(val_out, val_label) * 100.0\n",
    "                print(f\"Method: {m:<11} | AuPRC: {auprc:6.2f}% | FPR95: {fpr95:6.2f}%\")\n",
    "                \n",
    "        del scores_dict, ood_gts_list\n",
    "        gc.collect()"
   ]
