    "#Temperature\n",
    "import zipfile\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "from PIL import Image\n",
    "from sklearn.metrics import average_precision_score, roc_curve\n",
    "import gc\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "\n",
    "MODELS_PIPELINE = {\n",
    "    \"EoMT (Fine-Tuned)\": m_ft,\n",
    "    \"EoMT (CS Base)\": orig_cs_model,\n",
    "    \"EoMT (COCO Base)\": orig_coco_model\n",
    "}\n",
    "\n",
    "DATASETS = [\"RoadAnomaly21\", \"RoadObsticle21\", \"FS_LostFound_full\", \"fs_static\", \"RoadAnomaly\"]\n",
    "T_LIST = [1.0, 0.5, 0.75, 1.1]\n",
    "ZIP_PATH = \"/content/drive/MyDrive/Project/Anomaly_Validation_Datasets.zip\"\n",
    "\n",
    "def compute_calibrated_msp(logits, t=1.0):\n",
    "    if isinstance(logits, np.ndarray):\n",
    "        logits = torch.from_numpy(logits).float().to(device)\n",
    "    else:\n",
    "        logits = logits.float().to(device)\n",
    "    if logits.ndim == 4: \n",
    "        logits = logits[0]\n",
    "    if logits.shape[0] == 20: \n",
    "        logits = logits[:19, :, :]\n",
    "    scaled_logits = logits / t\n",
    "    probs = F.softmax(scaled_logits, dim=0)\n",
    "    max_prob, _ = torch.max(probs, dim=0)\n",
    "    return (1.0 - max_prob).cpu().numpy()\n",
    "\n",
    "def calculate_fpr_at_95_tpr(anomaly_scores, labels):\n",
    "    if len(np.unique(labels)) < 2: \n",
    "        return 1.0\n",
    "    fpr, tpr, thresholds = roc_curve(labels, anomaly_scores)\n",
    "    mask = tpr >= 0.95\n",
    "    if np.any(mask): \n",
    "        return fpr[np.where(mask)[0][0]]\n",
    "    return 1.0\n",
    "\n",
    "for model_name, model_obj in MODELS_PIPELINE.items():\n",
    "    model_obj.eval()\n",
    "    print(\"=\" * 80)\n",
    "    print(f\"CURRENT EVALUATION TARGET: {model_name}\")\n",
    "    print(\"=\" * 80)\n",
    "    for dataset_name in DATASETS:\n",
    "        print(f\"\\nProcessing Dataset: [{dataset_name}]\")\n",
    "        print(\"-\" * 60)\n",
    "        scores_dict = {t: [] for t in T_LIST}\n",
    "        ood_gts_list = []\n",
    "        with zipfile.ZipFile(ZIP_PATH, 'r') as zip_ref:\n",
    "            all_files_in_zip = zip_ref.namelist()\n",
    "            img_paths = sorted([f for f in all_files_in_zip if dataset_name in f and \"/images/\" in f and f.lower().endswith(('.png', '.jpg', '.webp'))])\n",
    "            if len(img_paths) == 0:\n",
    "                print(f\"No matching images found for [{dataset_name}]. Skipping.\")\n",
    "                continue\n",
    "            with torch.no_grad():\n",
    "                for img_path_in_zip in img_paths:\n",
    "                    with zip_ref.open(img_path_in_zip) as file:\n",
    "                        img_pil = Image.open(file).convert('RGB')\n",
    "                        img_pil = img_pil.resize((1024, 512), Image.BILINEAR)\n",
    "                        img_tensor = torch.from_numpy(np.array(img_pil)).permute(2, 0, 1).byte()\n",
    "                    imgs = [img_tensor.to(device)]\n",
    "                    img_sizes = [img_tensor.shape[-2:]]\n",
    "                    with torch.amp.autocast(dtype=torch.float16, device_type=\"cuda\"):\n",
    "                        crops, origins = model_obj.window_imgs_semantic(imgs)\n",
    "                        mask_logits_per_layer, class_logits_per_layer = model_obj(crops)\n",
    "                        target_size = crops.shape[-2:]\n",
    "                        mask_logits_up = F.interpolate(mask_logits_per_layer[-1], size=target_size, mode=\"bilinear\", align_corners=False)\n",
    "                        crop_logits = model_obj.to_per_pixel_logits_semantic(mask_logits_up, class_logits_per_layer[-1])\n",
    "                        logits = model_obj.revert_window_logits_semantic(crop_logits, origins, img_sizes)[0]\n",
    "                    gt_path_in_zip = img_path_in_zip.replace(\"/images/\", \"/labels_masks/\").rsplit('.', 1)[0] + '.png'\n",
    "                    try:\n",
    "                        with zip_ref.open(gt_path_in_zip) as file:\n",
    "                            mask = Image.open(file).resize((1024, 512), Image.NEAREST)\n",
    "                            raw_gts = np.array(mask)\n",
    "                    except KeyError:\n",
    "                        print(f\"  [Warning] Mask file not found: {gt_path_in_zip}, skipping.\")\n",
    "                        continue\n",
    "                    if raw_gts.ndim == 3: \n",
    "                        raw_gts = raw_gts[:, :, 0]\n",
    "                    ood_gts = np.full_like(raw_gts, 255, dtype=np.uint8)\n",
    "                    target_dataset_lower = dataset_name.lower()\n",
    "                    unique_vals = np.unique(raw_gts)\n",
    "                    is_already_standard = set(unique_vals).issubset({0, 1, 255})\n",
    "                    if is_already_standard or \"roadanomaly\" in target_dataset_lower or \"roadobsticle\" in target_dataset_lower:\n",
    "                        ood_gts[raw_gts == 0] = 0\n",
    "                        ood_gts[raw_gts == 1] = 1\n",
    "                        ood_gts[raw_gts == 2] = 1\n",
    "                    elif \"lostfound\" in target_dataset_lower or \"static\" in target_dataset_lower:\n",
    "                        ood_gts[raw_gts == 1] = 0\n",
    "                        ood_gts[(raw_gts > 1) & (raw_gts < 205)] = 1\n",
    "                        ood_gts[raw_gts == 0] = 255\n",
    "                    valid_mask = (ood_gts == 0) | (ood_gts == 1)\n",
    "                    if not np.any(valid_mask): \n",
    "                        continue\n",
    "                    valid_gts = ood_gts[valid_mask]\n",
    "                    ood_gts_list.append(valid_gts)\n",
    "                    for t in T_LIST:\n",
    "                        msp_map = compute_calibrated_msp(logits, t)\n",
    "                        scores_dict[t].append(msp_map[valid_mask])\n",
    "                    del logits, mask_logits_up, crop_logits, crops, origins\n",
    "                    torch.cuda.empty_cache()\n",
    "        if len(ood_gts_list) > 0:\n",
    "            val_label = np.concatenate(ood_gts_list)\n",
    "            best_t = 1.0\n",
    "            best_auprc = -1.0\n",
    "            best_fpr95 = float('inf')\n",
    "            for t in T_LIST:\n",
    "                val_out = np.concatenate(scores_dict[t])\n",
    "                auprc = average_precision_score(val_label, val_out) * 100.0\n",
    "                fpr95 = calculate_fpr_at_95_tpr(val_out, val_label) * 100.0\n",
    "                row_label = \"MSP\" if t == 1.0 else f\"MSP (t={t})\"\n",
    "                print(f\"[{model_name}] | {row_label:<14} | AuPRC: {auprc:5.2f}% | FPR95: {fpr95:5.2f}%\")\n",
    "                if auprc > best_auprc + 0.05:\n",
    "                    best_auprc = auprc\n",
    "                    best_fpr95 = fpr95\n",
    "                    best_t = t\n",
    "                elif abs(auprc - best_auprc) <= 0.05 and fpr95 < best_fpr95:\n",
    "                    best_auprc = auprc\n",
    "                    best_fpr95 = fpr95\n",
    "                    best_t = t\n",
    "            print(f\"[{model_name}] | MSP (best t={best_t}) | AuPRC: {best_auprc:5.2f}% | FPR95: {best_fpr95:5.2f}%\")\n",
    "        else:\n",
    "            print(f\"[{dataset_name}] Extraction failed: Please check if paths and masks contain 0 or 1.\")\n",
    "        del scores_dict, ood_gts_list\n",
    "        gc.collect()"
   ]
  }
